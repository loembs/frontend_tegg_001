# ================================
# TËGG API - Configuration
# ================================

# Serveur
NODE_ENV=development
PORT=3001

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=home_services_db
DB_USER=postgres
DB_PASSWORD=Passer_2026

# JWT
JWT_SECRET=changez_ce_secret_en_production_avec_une_chaine_aleatoire_de_64_caracteres
JWT_EXPIRES_IN=7d

# URLs Frontend
MOBILE_APP_URL=http://localhost:5173
ADMIN_DASHBOARD_URL=http://localhost:5173

# Wave API (Paiement Mobile Money)
# Obtenez vos identifiants sur https://wave.com/developers
WAVE_API_KEY=your_wave_api_key
WAVE_API_SECRET=your_wave_api_secret
WAVE_MERCHANT_ID=your_merchant_id
WAVE_WEBHOOK_SECRET=your_webhook_secret

# SMS OTP (Twilio)
# Créez un compte sur https://www.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+221XXXXXXXXX

# Alternative SMS (Orange SMS API)
ORANGE_SMS_CLIENT_ID=your_client_id
ORANGE_SMS_CLIENT_SECRET=your_client_secret
